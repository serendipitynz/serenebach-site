---
import BaseLayout from "../layouts/BaseLayout.astro";
import templates from "../data/generated/templates.json";
import type { Locale } from "../data/content";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const copy = {
  en: {
    title: "Serene Bach Templates",
    description: "Download template packages for Serene Bach.",
    homeLabel: "Back to home",
    languageLabel: "Language switcher",
    heroEyebrow: "Templates",
    heroLead: "Download ready-to-use template packages.",
    galleryLabel: "Template gallery",
    previewLabel: "Template preview",
    closeLabel: "Close",
    openPreview: (name: string) => `Open ${name} preview`,
    previewAlt: (name: string) => `${name} preview`,
    version: "Version",
    author: "Author",
    package: "Package",
    download: "Download",
    empty: "No templates are available yet.",
    filterPlaceholder: "Filter templates",
    filterClearLabel: "Clear filter",
    filterEmpty: "No templates match your filter.",
    lightLabel: "Light",
    darkLabel: "Dark",
    modeGroupLabel: "Preview color scheme",
  },
  ja: {
    title: "Serene Bach テンプレート",
    description: "Serene Bach で利用できるテンプレートをダウンロードできます。",
    homeLabel: "ホームへ戻る",
    languageLabel: "言語切り替え",
    heroEyebrow: "Templates",
    heroLead: "Serene Bach で利用できるテンプレートパッケージをダウンロードできます。",
    galleryLabel: "テンプレートギャラリー",
    previewLabel: "テンプレートプレビュー",
    closeLabel: "閉じる",
    openPreview: (name: string) => `${name} のプレビューを拡大表示`,
    previewAlt: (name: string) => `${name} のプレビュー`,
    version: "バージョン",
    author: "作者",
    package: "パッケージ",
    download: "ダウンロード",
    empty: "現在、利用できるテンプレートはありません。",
    filterPlaceholder: "テンプレートを絞り込む",
    filterClearLabel: "絞り込みをクリア",
    filterEmpty: "条件に一致するテンプレートはありません。",
    lightLabel: "ライト",
    darkLabel: "ダーク",
    modeGroupLabel: "プレビューの配色",
  },
}[lang];
const homeHref = lang === "ja" ? "/ja/" : "/";
const languageLinks = [
  { lang: "en", href: "/templates/", label: "English" },
  { lang: "ja", href: "/ja/templates/", label: "日本語" },
];
---

<BaseLayout title={copy.title} description={copy.description} lang={lang}>
  <header class="site-header">
    <a class="brand" href={homeHref} aria-label="Serene Bach home">
      <picture>
        <source srcset="/serenebach-logo-light.svg" media="(prefers-color-scheme: dark)" />
        <img src="/serenebach-logo.svg" alt="Serene Bach" />
      </picture>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      <div class="language-switch" aria-label={copy.languageLabel}>
        {languageLinks.map((item) => (
          <a href={item.href} aria-current={item.lang === lang ? "page" : undefined}>
            {item.label}
          </a>
        ))}
      </div>
      <a class="nav-icon-link template-home-link" href={homeHref} aria-label={copy.homeLabel}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 3.1 3 10.5l1.27 1.54L5.5 11.03V20h5.25v-5.25h2.5V20h5.25v-8.97l1.23 1.01L21 10.5 12 3.1Zm4.5 14.9h-1.25v-5.25h-6.5V18H7.5v-8.62L12 5.68l4.5 3.7V18Z"
          />
        </svg>
      </a>
    </nav>
  </header>

  <main>
    <section class="templates-hero">
      <p class="eyebrow">{copy.heroEyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="lead">{copy.heroLead}</p>
    </section>

    <section class="section templates-section" aria-label={copy.galleryLabel}>
      {
        templates.length > 0 ? (
          <>
            <div class="template-filter" data-template-filter>
              <input
                type="search"
                id="template-filter-input"
                placeholder={copy.filterPlaceholder}
                aria-label={copy.filterPlaceholder}
                autocomplete="off"
              />
              <button
                class="template-filter-clear"
                type="button"
                aria-label={copy.filterClearLabel}
                aria-controls="template-filter-input"
              >
                ×
              </button>
            </div>
            <div class="template-grid">
              {templates.map((template) => {
                const templateDescription = template.descriptions?.[lang] ?? template.descriptions?.en ?? "";
                const filterText = [template.name, template.author, templateDescription]
                  .filter(Boolean)
                  .join(" ")
                  .toLowerCase();

                return (
                  <article class="template-card" data-template-search={filterText}>
                  <button
                    class:list={["template-thumb", "template-preview-button", template.thumbnailDark && "has-dark"]}
                    type="button"
                    data-lightbox-src={template.thumbnail}
                    data-lightbox-src-dark={template.thumbnailDark ?? undefined}
                    data-lightbox-alt={copy.previewAlt(template.name)}
                    aria-label={copy.openPreview(template.name)}
                  >
                    <img class="template-thumb-light" src={template.thumbnail} alt={copy.previewAlt(template.name)} loading="lazy" />
                    {template.thumbnailDark && (
                      <img class="template-thumb-dark" src={template.thumbnailDark} alt="" aria-hidden="true" loading="lazy" />
                    )}
                  </button>
                  <div class="template-body">
                    <div>
                      <p class="template-version">{copy.version} {template.version}</p>
                      <h2>{template.name}</h2>
                      {templateDescription && <p>{templateDescription}</p>}
                    </div>
                    <dl class="template-meta">
                      <div>
                        <dt>{copy.author}</dt>
                        <dd>
                          {template.siteUrl ? (
                            <a href={template.siteUrl} rel="noreferrer">{template.author}</a>
                          ) : (
                            template.author
                          )}
                        </dd>
                      </div>
                      <div>
                        <dt>{copy.package}</dt>
                        <dd>{template.downloadName}</dd>
                      </div>
                    </dl>
                    <a class="button primary" href={template.download} download>
                      {copy.download}
                    </a>
                  </div>
                  </article>
                );
              })}
            </div>
            <p class="template-empty-filter" data-template-empty hidden>{copy.filterEmpty}</p>
          </>
        ) : (
          <p class="empty-state">{copy.empty}</p>
        )
      }
    </section>
  </main>

  <dialog class="lightbox" id="template-lightbox" aria-label={copy.previewLabel}>
    <button class="lightbox-close" type="button" aria-label={copy.closeLabel}>×</button>
    <div class="lightbox-mode-toggle" role="group" aria-label={copy.modeGroupLabel} hidden>
      <button type="button" data-lightbox-mode="light" aria-pressed="true">{copy.lightLabel}</button>
      <button type="button" data-lightbox-mode="dark" aria-pressed="false">{copy.darkLabel}</button>
    </div>
    <img src="" alt="" />
  </dialog>

  <script>
    const lightbox = document.querySelector<HTMLDialogElement>("#template-lightbox");
    const lightboxImage = lightbox?.querySelector("img");
    const closeButton = lightbox?.querySelector<HTMLButtonElement>(".lightbox-close");
    const modeToggle = lightbox?.querySelector<HTMLElement>(".lightbox-mode-toggle");
    const modeButtons = Array.from(
      lightbox?.querySelectorAll<HTMLButtonElement>("[data-lightbox-mode]") ?? [],
    );

    let currentLightSrc = "";
    let currentDarkSrc = "";

    function setLightboxMode(mode: "light" | "dark") {
      if (!lightboxImage) return;
      const target = mode === "dark" ? currentDarkSrc : currentLightSrc;
      if (!target) return;
      lightboxImage.src = target;
      for (const button of modeButtons) {
        button.setAttribute("aria-pressed", button.dataset.lightboxMode === mode ? "true" : "false");
      }
    }

    function pickInitialMode(button: HTMLButtonElement, event: MouseEvent): "light" | "dark" {
      if (!currentDarkSrc) return "light";
      const rect = button.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return "light";
      const x = event.clientX - rect.left;
      const y = event.clientY - rect.top;
      // diagonal cuts from (width, 0) to (0, height); below-the-line is the dark half
      return x * rect.height + y * rect.width >= rect.width * rect.height ? "dark" : "light";
    }

    document.querySelectorAll<HTMLButtonElement>("[data-lightbox-src]").forEach((button) => {
      button.addEventListener("click", (event) => {
        if (!lightbox || !lightboxImage) return;

        currentLightSrc = button.dataset.lightboxSrc ?? "";
        currentDarkSrc = button.dataset.lightboxSrcDark ?? "";
        lightboxImage.alt = button.dataset.lightboxAlt ?? "";

        if (modeToggle) modeToggle.hidden = !currentDarkSrc;
        setLightboxMode(pickInitialMode(button, event));
        lightbox.showModal();
      });
    });

    for (const button of modeButtons) {
      button.addEventListener("click", () => {
        const mode = button.dataset.lightboxMode === "dark" ? "dark" : "light";
        setLightboxMode(mode);
      });
    }

    closeButton?.addEventListener("click", () => lightbox?.close());
    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) {
        lightbox.close();
      }
    });

    const filterContainer = document.querySelector<HTMLElement>("[data-template-filter]");
    const filterInput = filterContainer?.querySelector<HTMLInputElement>("input");
    const filterClear = filterContainer?.querySelector<HTMLButtonElement>(".template-filter-clear");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".template-card[data-template-search]"));
    const emptyMessage = document.querySelector<HTMLElement>("[data-template-empty]");

    function applyFilter(rawValue: string) {
      const query = rawValue.trim().toLowerCase();
      let visibleCount = 0;
      for (const card of cards) {
        const haystack = card.dataset.templateSearch ?? "";
        const matched = query === "" || haystack.includes(query);
        card.hidden = !matched;
        if (matched) visibleCount += 1;
      }
      if (emptyMessage) emptyMessage.hidden = visibleCount > 0 || cards.length === 0;
      if (filterContainer) filterContainer.dataset.hasValue = rawValue.length > 0 ? "true" : "false";
    }

    filterInput?.addEventListener("input", (event) => {
      applyFilter((event.target as HTMLInputElement).value);
    });

    filterClear?.addEventListener("click", () => {
      if (!filterInput) return;
      filterInput.value = "";
      applyFilter("");
      filterInput.focus();
    });

    if (filterInput) applyFilter(filterInput.value);
  </script>
</BaseLayout>
